{
  "name": "tavily-web-search",
  "version": "1.0.0",
  "description": "Tavily Web Search - Full-featured Tavily API integration for OpenClaw",
  "author": "brucetangc",
  "license": "MIT-0",
  "main": "index.js",
  "scripts": {
    "start": "node -e \"const t=require('./index');console.log('Tavily Web Search v'+require('./package.json').version);\"",
    "validate": "node scripts/validate-config.js",
    "update": "node scripts/update-from-docs.js",
    "check-updates": "node scripts/check-updates.js",
    "cache:clear": "node -e \"const {cache}=require('./utils/cache');cache.clear();console.log('缓存已清空');\"",
    "cache:stats": "node -e \"const {cache}=require('./utils/cache');console.log('缓存统计:',cache.stats());\""
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "keywords": [
    "tavily",
    "search",
    "web-search",
    "extract",
    "openclaw",
    "skill"
  ],
  "tavily": {
    "api_version": "1.0.0",
    "docs_version": "2026-04-05",
    "last_updated": "2026-04-05T13:11:00Z",
    "commands": {
      "search": { "enabled": true },
      "extract": { "enabled": true },
      "usage": { "enabled": true },
      "crawl": { "enabled": false },
      "map": { "enabled": false },
      "research": { "enabled": false },
      "research_status": { "enabled": false }
    }
  }
}
