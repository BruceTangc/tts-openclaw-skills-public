{
  "name": "excel-generator",
  "version": "1.0.0",
  "description": "Excel 文件生成工具，基于 openpyxl 和 xlsxwriter",
  "author": "brucetangc",
  "homepage": "https://openpyxl.readthedocs.io",
  "repository": {
    "type": "git",
