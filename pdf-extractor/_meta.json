    "lastCheck": null,
    "lastUpdate": null
  },
  "dependencies": {
    "python": ">=3.8",
    "pymupdf": ">=1.23.0"
  },
  "changelog": {
    "1.0.0": {
      "date": "2026-04-07",
      "changes": [
        "初始版本",
        "支持 extract、info、search、to-markdown 命令",
        "实现自动更新功能"
      ]
    }
  }
}
