{
  "name": "pdf-extractor",
  "version": "1.0.0",
  "description": "PyMuPDF-based PDF text extraction with auto-update",
  "author": "brucetangc",
  "homepage": "https://pymupdf.readthedocs.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/BruceTangc/tts-openclaw-skills-public.git",
    "directory": "pdf-extractor"
  },
  "update": {
    "enabled": true,
    "checkCommand": "npm run check-updates",
